#!/bin/bash

COMMAND="$1"
shift

case "$COMMAND" in

    deploy)
        exec "$(dirname "$0")/../lib/deploy.sh" "$@"
        ;;

    status)
        exec "$(dirname "$0")/../lib/status.sh" "$@"
        ;;

    submit)
        exec "$(dirname "$0")/../lib/submit.sh" "$@"
        ;;

    gpu)
        exec "$(dirname "$0")/../lib/gpu.sh" "$@"
        ;;

    doctor)
        exec "$(dirname "$0")/../lib/doctor.sh" "$@"
        ;;

    benchmark)
        exec "$(dirname "$0")/../lib/benchmark.sh" "$@"
        ;;

    finish)
        exec "$(dirname "$0")/../lib/finish.sh" "$@"
        ;;

    fetch)
        exec "$(dirname "$0")/../lib/fetch.sh" "$@"
    	;;

    history)
        exec "$(dirname "$0")/../lib/history.sh" "$@"
        ;;

    update-history)
        exec "$(dirname "$0")/../lib/update-history.sh" "$@"
        ;;

    *)
        echo
        echo "Available commands:"
        echo
        echo " panda deploy"
        echo " panda status"
        echo " panda submit"
	echo " panda fetch"
	echo " panda finish"
        echo " panda gpu"
        echo " panda doctor"
        echo " panda benchmark"
        ;;
esac
